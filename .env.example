# ==============================================================================
# TradeCouncil 環境変数テンプレート(シークレットはこのファイルに集約する)
#
# このファイルを .env にコピーして値を設定する(.env は git 追跡されない):
#   copy .env.example .env
#
# 解決順: OS 環境変数 → この .env → .claude/settings.local.json の env(後方互換)
# 使う機能のものだけ設定すればよい。未設定の機能は安全側(通知=ログfallback、
# ブリッジ=エラー、SharePoint=ローカルのみ)に倒れる。
# ==============================================================================

# --- 通知(core/notify。backend は config/system.yaml の notify.backend で選択)---

# Teams 通知用 Power Automate Workflow URL(notify.backend: teams のとき使用)
# Teams の Workflows アプリ「Webhook 要求を受信したらチャネルに投稿する」フローの HTTP URL。
# sig= の SAS 署名を含む秘密情報。手順: docs/setup/teams-notification-setup.md
#
# マルチチャネル(ADR-0003): TEAMS_WORKFLOW_URL_<チャネル名大文字> でチャネル別 URL を設定。
# 未設定チャネルへの通知は TEAMS_WORKFLOW_URL(default)へフォールバックするため、
# まず default 1本だけでも運用できる。severity→チャネルの振り分けは system.yaml の notify.routing
TEAMS_WORKFLOW_URL=
#TEAMS_WORKFLOW_URL_OPS=        # 📢 運用通知(info 全般・約定・日次サマリ)
#TEAMS_WORKFLOW_URL_ALERTS=     # 🚨 アラート(warning・critical)
#TEAMS_WORKFLOW_URL_GOVERNANCE= # 📜 ガバナンス(提案・決裁・会議)
#TEAMS_WORKFLOW_URL_REPORTS=    # 📊 レポート(週次KPI・月次レビュー)

# Discord Webhook URL(notify.backend: discord のとき使用。予備チャネル)
# チャネル別は DISCORD_WEBHOOK_URL_<チャネル名大文字>(Teams と対称)
DISCORD_WEBHOOK_URL=

# --- LLM ブリッジ(scripts/ask_openai.py / ask_gemini.py)---

# 人格を backend: openai で動かす場合のみ必須
OPENAI_API_KEY=
# 通常は不要。Azure OpenAI / 互換プロキシ経由のときだけ設定する
#OPENAI_BASE_URL=https://api.openai.com/v1

# 人格を backend: gemini で動かす場合のみ必須(Google AI Studio の API キー)
GEMINI_API_KEY=
# 通常は不要。プロキシ経由のときだけ設定する
#GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# --- SharePoint 連携(scripts/sharepoint.py。使う場合のみ)---

# 連携のオンオフ。true で sharepoint/ root を使い同期、false(既定)で local/ の純ローカル
#MAGI_SHAREPOINT_ENABLED=false
# 対象サイト URL(sharepoint.config.json の値を上書きする)
#MAGI_SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
# 任意: ドキュメントライブラリ名 / ミラー基点フォルダ(既定は config の値)
#MAGI_SHAREPOINT_DRIVE=Documents
#MAGI_SHAREPOINT_ROOT=MAGI
# enabled=true のとき必須。Azure アプリ登録の値
# (prototype/documents/sharepoint-azure-app-setup.md 参照)
#MAGI_SHAREPOINT_TENANT_ID=
#MAGI_SHAREPOINT_CLIENT_ID=
#MAGI_SHAREPOINT_CLIENT_SECRET=
