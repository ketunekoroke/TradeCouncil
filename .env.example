# ==============================================================================
# モノレポ 環境変数テンプレート(シークレットはこのルート共有ファイルに集約する)
#
# このファイルを .env にコピーして値を設定する(.env は git 追跡されない):
#   copy .env.example .env
#
# 解決順: OS 環境変数 → ルート共有 .env → .claude/settings.local.json の env(後方互換)
# 使う機能のものだけ設定すればよい。未設定の機能は安全側(通知=ログfallback、
# ブリッジ=エラー、SharePoint=ローカルのみ)に倒れる。
#
# 命名規約(ADR-0011): 環境変数は**共有層の設定**にのみ使い、ドメイン別プレフィックスで
# 名付ける(プロジェクト名は使わない)。SHAREPOINT_* / BRIDGE_* / OFFICE_* / プロバイダ標準
# キー(OPENAI_API_KEY / GEMINI_API_KEY)。プロジェクトごとに異なるレイアウト(SharePoint の
# 同期先 root 等)は各 */sharepoint.config.json で持つ(env では分けられない)。
# 旧 MAGI_* 名は後方互換で読まれるが非推奨。
# ==============================================================================

# --- 通知(TradeCouncil/core/notify。backend は config/system.yaml の notify.backend で選択)---
# env 名は**プロジェクト別プレフィックス**(TradeCouncil = TC。system.yaml の notify.env_prefix)。
#   TEAMS_TC_WORKFLOW_URL[_<チャネル名大文字>] / DISCORD_TC_WEBHOOK_URL[_<チャネル名大文字>]
# どのプロジェクトの通知か名前で分かる。無印の TEAMS_WORKFLOW_URL[...] も後方互換で読む(ADR-0011)。

# Teams 通知用 Power Automate Workflow URL(notify.backend: teams のとき使用)
# Teams の Workflows アプリ「Webhook 要求を受信したらチャネルに投稿する」フローの HTTP URL。
# sig= の SAS 署名を含む秘密情報。手順: TradeCouncil/docs/setup/teams-notification-setup.md
#
# マルチチャネル(ADR-0003): TEAMS_TC_WORKFLOW_URL_<チャネル名大文字> でチャネル別 URL を設定。
# 未設定チャネルへの通知は TEAMS_TC_WORKFLOW_URL(default)へフォールバックするため、
# まず default 1本だけでも運用できる。severity→チャネルの振り分けは system.yaml の notify.routing
TEAMS_TC_WORKFLOW_URL=
#TEAMS_TC_WORKFLOW_URL_OPS=        # 📢 運用通知(info 全般・約定・日次サマリ)
#TEAMS_TC_WORKFLOW_URL_ALERTS=     # 🚨 アラート(warning・critical)
#TEAMS_TC_WORKFLOW_URL_GOVERNANCE= # 📜 ガバナンス(提案・決裁・会議)
#TEAMS_TC_WORKFLOW_URL_REPORTS=    # 📊 レポート(週次KPI・月次レビュー)

# Discord Webhook URL(notify.backend: discord のとき使用。予備チャネル)
# チャネル別は DISCORD_TC_WEBHOOK_URL_<チャネル名大文字>(Teams と対称)
DISCORD_TC_WEBHOOK_URL=

# --- 通知(Accounting/core/notify。env_prefix は Accounting = AC。system.yaml の notify.env_prefix)---
# 会計経理の通知(Teams 確認カード・月次レビュー・要確認フラグ)。未設定なら log フォールバック。
#TEAMS_AC_WORKFLOW_URL=             # default チャネル
#TEAMS_AC_WORKFLOW_URL_REVIEWS=    # 📊 レビュー(月次・要確認の棚卸し)
#DISCORD_AC_WEBHOOK_URL=           # 予備チャネル

# --- Bybit testnet(core/exchange/bybit.py — ADR-0008)---

# testnet 専用キー(https://testnet.bybit.com で作成。mainnet のキーではない)。
# 権限は Spot Trade のみ・Withdraw 不可で作る。手順: docs/setup/bybit-testnet-setup.md
# 未設定なら bybit_testnet ブローカーの BOT は起動時に即エラー(fail-closed)
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=

# --- MoneyForward API(Accounting/core/moneyforward.py。会計バックエンド連携)---
# ドメイン別プレフィックス MONEYFORWARD_*(BYBIT_* と同じく、プロジェクト名ではなく接続先で名付ける)。
# 非秘密の URL・client_id・scopes は Accounting/config/moneyforward.config.json に置く(env でも上書き可)。
# 各フィールドの解決順: MONEYFORWARD_AC_<FIELD> → config の値 → MONEYFORWARD_<FIELD>。
#
# 秘密(client_secret)は必ず env に置く。未設定なら `ac mf config --check` が未完了として失敗する。
# 正確なエンドポイント/スコープ/グラントは製品ドメインの Swagger・開発者ポータルで確認すること。
#MONEYFORWARD_CLIENT_ID=
MONEYFORWARD_CLIENT_SECRET=
# 任意の上書き(config に書かず env で渡す場合)。AC=Accounting の env_prefix。
#MONEYFORWARD_TOKEN_URL=
#MONEYFORWARD_AUTHORIZE_URL=
#MONEYFORWARD_AC_CLIENT_SECRET=    # プロジェクト別に分ける場合(共有 MONEYFORWARD_CLIENT_SECRET より優先)
# spike(scripts/spike_moneyforward.py)の grant 調整(任意)
#MONEYFORWARD_GRANT_TYPE=client_credentials
#MONEYFORWARD_AUTH_CODE=
#MONEYFORWARD_OFFICES_URL=

# --- LLM ブリッジ(shared/ask_openai.py / ask_gemini.py)---

# 人格を backend: openai で動かす場合のみ必須
OPENAI_API_KEY=
# 通常は不要。Azure OpenAI / 互換プロキシ経由のときだけ設定する
#OPENAI_BASE_URL=https://api.openai.com/v1

# 人格を backend: gemini で動かす場合のみ必須(Google AI Studio の API キー)
GEMINI_API_KEY=
# 通常は不要。プロキシ経由のときだけ設定する
#GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# 任意: ブリッジ実行設定(全プロジェクト共通。BRIDGE_*)
#BRIDGE_HTTP_MAX_RETRIES=4
#BRIDGE_HTTP_TIMEOUT=180
#BRIDGE_GEN_MAX_RETRIES=1
#BRIDGE_OPENAI_FALLBACK_MODEL=
#BRIDGE_GEMINI_FALLBACK_MODEL=

# --- SharePoint 連携(shared/sharepoint.py。使う場合のみ。SHAREPOINT_*)---
# 各フィールドの解決順: プロジェクト別 env(SHAREPOINT_<prefix>_*)→ config の値 → 共有 env。
# env_prefix は各 */sharepoint.config.json に定義(Magi="MAGI" / TradeCouncil="TC" / Accounting="AC")。
#
# (1) 全プロジェクト共通でよい場合(同一テナント・同一サイト・同一アプリ登録): 共有 SHAREPOINT_* だけ
#SHAREPOINT_ENABLED=false
#SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
#SHAREPOINT_DRIVE=Documents
#SHAREPOINT_TENANT_ID=<ディレクトリ (テナント) ID>
#SHAREPOINT_CLIENT_ID=<アプリケーション (クライアント) ID>
#SHAREPOINT_CLIENT_SECRET=<クライアント シークレットの値>
#
# (2) プロジェクトごとにサイト・クライアントを変える場合:
#     識別子(site_url/tenant_id/client_id)は各 */sharepoint.config.json に直接書ける(非秘密)。
#     client_secret は秘密なので env に置く。プロジェクト別アプリ登録なら下記のように分ける:
#SHAREPOINT_MAGI_SITE_URL=https://<tenant>.sharepoint.com/sites/<magi-site>
#SHAREPOINT_MAGI_CLIENT_ID=<Magi アプリの client id>
#SHAREPOINT_MAGI_CLIENT_SECRET=<Magi アプリの secret>
#SHAREPOINT_TC_SITE_URL=https://<tenant>.sharepoint.com/sites/<trade-site>
#SHAREPOINT_TC_CLIENT_ID=<TradeCouncil アプリの client id>
#SHAREPOINT_TC_CLIENT_SECRET=<TradeCouncil アプリの secret>
#SHAREPOINT_AC_SITE_URL=https://<tenant>.sharepoint.com/sites/<accounting-site>
#SHAREPOINT_AC_CLIENT_ID=<Accounting アプリの client id>
#SHAREPOINT_AC_CLIENT_SECRET=<Accounting アプリの secret>
# 注: 同期先フォルダ(root)はプロジェクトごとに */sharepoint.config.json で持つ
#     (Magi="MAGI" / TradeCouncil="TC" / Accounting="AC")。
# 手順: TradeCouncil/docs/setup/sharepoint-azure-app-setup.md
