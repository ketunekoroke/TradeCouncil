# ==============================================================================
# モノレポ .gitignore(ADR-0011)
#
# Magi / TradeCouncil / shared の各プロジェクト dir を横断して除外する。
# 実行時生成物(var)・シナリオ入出力(workspace)はどのプロジェクト配下でも除外。
# ==============================================================================

# ------------------------------------------------------------------------------
# Python(TradeCouncil 本体)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
build/
dist/

# ------------------------------------------------------------------------------
# 実行時生成物(どのプロジェクト配下でも除外 — TradeCouncil/var など)
# ------------------------------------------------------------------------------
var/
var-*/
reports/
*.db
*.db-wal
*.db-shm
*.sqlite3

# ------------------------------------------------------------------------------
# シナリオ入出力 workspace/(個人情報・容量の理由でデフォルト除外 — ADR-0009)
# 各プロジェクト配下の workspace/ を横断除外。.gitkeep / README のみ追跡
# ------------------------------------------------------------------------------
**/workspace/**
!**/workspace/**/
!**/workspace/**/.gitkeep
!**/workspace/README.md
!**/workspace/**/README.md
# 会議議事録(.md)は監査テキストとして git 追跡する(ADR-0005)。メディアは除外のまま
!**/workspace/council/**/*.md

# ------------------------------------------------------------------------------
# OS生成ファイル(全ディレクトリ共通)
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ------------------------------------------------------------------------------
# エディタ・IDE(全ディレクトリ共通)
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
.project
.classpath
.settings/

# ------------------------------------------------------------------------------
# Claude Code ローカル設定
# ------------------------------------------------------------------------------
.claude/settings.local.json
.claude/cache/
.claude/.session/
.claude/logs/

# ------------------------------------------------------------------------------
# シークレット類(全ディレクトリで絶対に追跡しない)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
secrets/

# ------------------------------------------------------------------------------
# ログ・一時ファイル
# ------------------------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
.cache/
tmp/

# ------------------------------------------------------------------------------
# アーカイブ(誤コミット防止)
# ------------------------------------------------------------------------------
*.zip
*.tar.gz
*.7z
*.rar

# 注:
# - ミラー状態ファイル等は各プロジェクトの var/ に入り上の var/ ルールで除外される
