# ==============================================================================
# TradeCouncil .gitignore
#
# prototype/ には独自の .gitignore があります(MAGI プロトタイプ用)。
# Gitは階層的に評価するため、ここにはルート(TradeCouncil 本体)の除外を書きます。
# ==============================================================================

# ------------------------------------------------------------------------------
# Python(TradeCouncil 本体)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
build/
dist/

# ------------------------------------------------------------------------------
# TradeCouncil 実行時生成物
# ------------------------------------------------------------------------------
/var/
/var-*/
/reports/
*.db
*.db-wal
*.db-shm
*.sqlite3

# ------------------------------------------------------------------------------
# シナリオ入出力ルート(個人情報・容量の理由でデフォルト除外)
# .gitkeep / README のみ追跡。個別共有は `git add -f <path>` で可能
# ------------------------------------------------------------------------------
/local/**
/sharepoint/**
!/local/**/
!/sharepoint/**/
!/local/**/.gitkeep
!/sharepoint/**/.gitkeep
!/local/README.md
!/sharepoint/README.md
!/local/**/README.md
!/sharepoint/**/README.md
# 会議議事録(.md)は監査テキストとして git 追跡する(ADR-0005)。メディアは除外のまま
!/local/council/**/*.md
!/sharepoint/council/**/*.md

# ------------------------------------------------------------------------------
# OS生成ファイル(全ディレクトリ共通)
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ------------------------------------------------------------------------------
# エディタ・IDE(全ディレクトリ共通)
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
.project
.classpath
.settings/

# ------------------------------------------------------------------------------
# Claude Code ローカル設定
# ------------------------------------------------------------------------------
.claude/settings.local.json
.claude/cache/
.claude/.session/
.claude/logs/

# ------------------------------------------------------------------------------
# シークレット類(全ディレクトリで絶対に追跡しない)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
secrets/

# ------------------------------------------------------------------------------
# ログ・一時ファイル
# ------------------------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
.cache/
tmp/

# ------------------------------------------------------------------------------
# アーカイブ(誤コミット防止)
# ------------------------------------------------------------------------------
*.zip
*.tar.gz
*.7z
*.rar

# 注:
# - prototype/ 配下の除外(議論ログ・メディア等)→ prototype/.gitignore
