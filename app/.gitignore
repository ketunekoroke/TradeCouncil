# ==============================================================================
# MAGI App .gitignore (Next.js project)
# ==============================================================================

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
.nyc_output
/playwright-report
/test-results
/.swc

# Next.js
/.next/
/out/
/build

# Production
*.tsbuildinfo
next-env.d.ts

# Misc
.DS_Store
*.pem
Thumbs.db
desktop.ini

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env files
.env
.env*.local
!.env.example

# Vercel
.vercel

# Editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
.Trash-*

# Database (dev)
*.db
*.db-journal
*.sqlite
*.sqlite3
/drizzle/migrations/meta/*.json
!/drizzle/migrations/meta/_journal.json

# Generated deliverables (本番では別ストレージに保存する想定)
/storage/deliberations/*
!/storage/deliberations/.gitkeep
/storage/media/*
!/storage/media/.gitkeep

# Logs
*.log
logs/

# Claude Code local
.claude/settings.local.json
.claude/cache/

# Misc
*.tmp
*.bak
.cache/
