# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Testing & linting
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# Node.js (将来の拡張用)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ------------------------------------------------------------------------------
# OS生成ファイル
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ------------------------------------------------------------------------------
# エディタ / IDE
# ------------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
*.bak
.project
.classpath
.settings/

# ------------------------------------------------------------------------------
# 環境変数 / シークレット
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
secrets/

# ------------------------------------------------------------------------------
# Claude Code ローカル設定(ユーザー固有のもの)
# ------------------------------------------------------------------------------
.claude/settings.local.json
.claude/cache/
.claude/.session/
.claude/logs/

# 注: .claude/agents/*.md は人格定義なので追跡する(無視しない)

# ------------------------------------------------------------------------------
# MAGI 入出力(個人情報・容量の理由でデフォルト除外)
# ------------------------------------------------------------------------------
# 入出力は2つのマウント root に集約される(sharepoint.config.json の enabled で切替):
#   local/      … SharePoint 不使用時(enabled=false)の root
#   sharepoint/ … SharePoint 連携時(enabled=true)のローカルミラー(pull/push で同期)
# 両 root とも input / media-output / reviews / deliberations の構成は同一。
# 中身は無視し、.gitkeep / README.md / samples / templates のみ追跡する。
# 個別に共有/バックアップしたいファイルは `git add -f <path>` で強制追加できる。
local/**
sharepoint/**
# ディレクトリは辿れるよう再包含(中のファイルは上で除外済み)
!local/**/
!sharepoint/**/
# 追跡したいプレースホルダ・説明・サンプル・テンプレートだけ戻す
!local/**/.gitkeep
!sharepoint/**/.gitkeep
!local/README.md
!sharepoint/README.md
!local/**/README.md
!sharepoint/**/README.md
!local/**/samples/**
!sharepoint/**/samples/**
!local/**/templates/**
!sharepoint/**/templates/**

# ------------------------------------------------------------------------------
# ログ・一時ファイル
# ------------------------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
.cache/
tmp/

# ------------------------------------------------------------------------------
# アーカイブ(誤コミット防止)
# ------------------------------------------------------------------------------
*.zip
*.tar.gz
*.7z
*.rar
